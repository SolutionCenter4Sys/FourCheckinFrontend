{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/**", "/*.ico", "/*.svg", "/*.png", "/*.webp", "/*.woff2"]
  },
  "globalHeaders": {
    "x-content-type-options": "nosniff",
    "x-frame-options": "DENY",
    "x-xss-protection": "1; mode=block"
  },
  "mimeTypes": {
    ".js": "text/javascript",
    ".mjs": "text/javascript",
    ".css": "text/css",
    ".json": "application/json",
    ".svg": "image/svg+xml"
  }
}
